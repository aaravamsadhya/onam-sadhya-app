# Copy these into Railway's Variables tab (Settings > Variables), one at a time.
# Do not put quotes or extra text around the values.

# Named committee logins for the Admin page. Each person gets their own PIN, and the admin
# console shows "Logged in as: <name>" and records who confirmed/rejected each registration.
# Must be valid JSON on a single line, no line breaks. Add/remove/change people by editing this.
# Example with the current committee:
ADMIN_USERS=[{"name":"Arjun Cheruvathari","pin":"9686993334"},{"name":"Anu George","pin":"9738461328"},{"name":"Binoj Mathew","pin":"9739977478"}]

# (Legacy/fallback) Only used if ADMIN_USERS above is not set at all - a single shared PIN
# under the name "Committee". You can delete this once ADMIN_USERS is set.
ADMIN_PIN=1234

# View-only admin PIN. Logging in with this PIN (name "roadmin") shows the full dashboard but
# hides every button that changes data - no confirm, reject, edit, delete, refund, or WhatsApp
# send. Safe to hand out to anyone who just needs to check status. Defaults to 1234 if you don't
# set this - since your real ADMIN_USERS PINs above are full phone numbers, that default won't
# collide with anything. Change it here if you want a different view-only PIN.
ADMIN_READONLY_PIN=1234

# Committee-only PIN to unlock the entrance Scanner page
SCANNER_PIN=5678

# Your UPI ID that residents will pay to (shown as a QR code on the registration page)
UPI_ID=your-upi-id@bank

# Name shown alongside the UPI QR code
UPI_NAME=Aaravam Sadhya Committee

# Price per adult, in rupees (numbers only, no currency symbol)
PRICE_ADULT=450

# Price per kid, in rupees (numbers only, no currency symbol)
PRICE_KID=250

# DATABASE_URL and PORT are provided automatically by Railway - you do not need to set these yourself.
